generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  ANGAJAT
  ADMINISTRATOR
}

enum EnrollmentStatus {
  NEINCEPUT
  IN_CURS
  PROMOVAT
  RESPINS
}

enum MaterialTip {
  VIDEO
  PDF
  PPTX
}

model Structura {
  id        String     @id @default(cuid())
  nume      String     @unique
  angajati  Angajat[]
}

model Angajat {
  id                 String        @id @default(cuid())
  nume               String
  prenume            String
  email              String        @unique
  parola             String?
  functie            String
  role               Role          @default(ANGAJAT)
  structura          Structura     @relation(fields: [structuraId], references: [id])
  structuraId        String
  consimtamantGDPR   Boolean       @default(false)
  consimtamantData   DateTime?
  fotoUrl            String?       @db.Text
  enrollments        Enrollment[]
  testResults        TestResult[]
  testFinalResults   TestFinalResult[]
  createdAt          DateTime      @default(now())
}

model Curs {
  id           String        @id @default(cuid())
  titlu        String
  descriere    String?
  icon         String        @default("shield")
  ordine       Int           @default(0)
  lectii       Lectie[]
  materiale    Material[]
  intrebari    Intrebare[]
  enrollments  Enrollment[]
  teste        Test[]
  testFinal    TestFinal?
  createdAt    DateTime      @default(now())
}

model Lectie {
  id        String   @id @default(cuid())
  curs      Curs     @relation(fields: [cursId], references: [id])
  cursId    String
  titlu     String
  ordine    Int      @default(0)
  durataMin Int      @default(10)
}

model Enrollment {
  id            String            @id @default(cuid())
  angajat       Angajat           @relation(fields: [angajatId], references: [id])
  angajatId     String
  curs          Curs              @relation(fields: [cursId], references: [id])
  cursId        String
  status        EnrollmentStatus  @default(NEINCEPUT)
  vizualizat    Boolean           @default(false)
  lectiiFinal   Int               @default(0)
  progresPct    Int               @default(0)
  actualizatLa  DateTime          @updatedAt

  @@unique([angajatId, cursId])
}

model Test {
  id            String        @id @default(cuid())
  curs          Curs          @relation(fields: [cursId], references: [id])
  cursId        String        @unique
  titlu         String        @default("Test intermediar")
  durataMin     Int           @default(15)
  nrIntrebari   Int           @default(30)
  dataLimita    DateTime?
  rezultate     TestResult[]
}

model TestResult {
  id         String    @id @default(cuid())
  test       Test      @relation(fields: [testId], references: [id])
  testId     String
  angajat    Angajat   @relation(fields: [angajatId], references: [id])
  angajatId  String
  scor       Int
  dinTotal   Int       @default(10)
  promovat   Boolean
  susTinutLa DateTime  @default(now())
}

model Material {
  id        String      @id @default(cuid())
  curs      Curs        @relation(fields: [cursId], references: [id])
  cursId    String
  tip       MaterialTip
  titlu     String
  url       String      @db.Text
  createdAt DateTime    @default(now())
}

model Intrebare {
  id       String    @id @default(cuid())
  curs     Curs      @relation(fields: [cursId], references: [id])
  cursId   String
  enunt    String
  ordine   Int       @default(0)
  optiuni  Optiune[]
}

model Optiune {
  id          String    @id @default(cuid())
  intrebare   Intrebare @relation(fields: [intrebareId], references: [id])
  intrebareId String
  text        String
  corecta     Boolean   @default(false)
}

model TestFinal {
  id          String            @id @default(cuid())
  curs        Curs              @relation(fields: [cursId], references: [id])
  cursId      String            @unique
  titlu       String            @default("Test final")
  activ       Boolean           @default(false)
  nrIntrebari Int               @default(20)
  dataLimita  DateTime?
  createdAt   DateTime          @default(now())
  rezultate   TestFinalResult[]
}

model TestFinalResult {
  id          String    @id @default(cuid())
  testFinal   TestFinal @relation(fields: [testFinalId], references: [id])
  testFinalId String
  angajat     Angajat   @relation(fields: [angajatId], references: [id])
  angajatId   String
  scor        Int
  dinTotal    Int
  promovat    Boolean
  semnatura   String    @db.Text
  raspunsuriDetaliu String? @db.Text
  susTinutLa  DateTime  @default(now())

  @@unique([testFinalId, angajatId])
}

model ActivitateLog {
  id        String   @id @default(cuid())
  angajatId String
  mesaj     String
  createdAt DateTime @default(now())
}